# ── Required ──────────────────────────────────────────────────────────────────

[providers.github]
token = "ghp_..."
repos = ["org/api", "org/frontend"]

# ── LLM narrative (optional) ──────────────────────────────────────────────────
# If omitted, reports are generated without AI summary/highlights.
# Uses LiteLLM model strings — see https://docs.litellm.ai/docs/providers

# Anthropic Claude:
# [llm]
# model   = "anthropic/claude-opus-4-7"
# api_key = "sk-ant-..."

# OpenAI:
# [llm]
# model   = "openai/gpt-4o"
# api_key = "sk-..."

# Google Gemini:
# [llm]
# model   = "gemini/gemini-1.5-pro"
# api_key = "..."

# Ollama (local, no api_key needed):
# [llm]
# model    = "ollama/llama3"
# api_base = "http://localhost:11434"

# ── Optional providers (add any combination) ──────────────────────────────────

# [providers.datadog]
# api_key    = "..."
# app_key    = "..."
# dashboards = ["abc123", "def456"]   # dashboard IDs to pull metrics from

# [providers.linear]
# api_key  = "..."
# team_ids = ["TEAM-1"]

# [providers.pagerduty]
# api_key = "..."

# [providers.sentry]
# auth_token = "..."
# org_slug   = "myorg"

# ── Service map (used for metric attribution) ─────────────────────────────────
# Maps Datadog/Linear service tags to git path prefixes.
# Credit for an improved metric is distributed proportionally across authors
# who committed to the matching path during the evaluation period.

# [service_map]
# "api-gateway" = "services/api/"
# "frontend"    = "apps/frontend/"

# ── Output ────────────────────────────────────────────────────────────────────

[output]
path = "./reports"
