# ── Required ──────────────────────────────────────────────────────────────────

[providers.github]
token = "ghp_..."
repos = ["org/api", "org/frontend"]

[anthropic]
api_key = "..."
model   = "claude-opus-4-7"

# ── Optional providers (add any combination) ──────────────────────────────────

# [providers.datadog]
# api_key    = "..."
# app_key    = "..."
# dashboards = ["abc123", "def456"]   # dashboard IDs to pull metrics from

# [providers.linear]
# api_key  = "..."
# team_ids = ["TEAM-1"]

# [providers.pagerduty]
# api_key = "..."

# [providers.sentry]
# auth_token = "..."
# org_slug   = "myorg"

# ── Service map (used for metric attribution) ─────────────────────────────────
# Maps Datadog/Linear service tags to git path prefixes.
# Credit for an improved metric is distributed proportionally across authors
# who committed to the matching path during the evaluation period.

# [service_map]
# "api-gateway" = "services/api/"
# "frontend"    = "apps/frontend/"

# ── Output ────────────────────────────────────────────────────────────────────

[output]
path = "./reports"
